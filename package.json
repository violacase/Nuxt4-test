{
  "name": "vue3-test",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "fuser -k 3332/tcp 3333/tcp || true && concurrently --kill-others-on-fail --names \"vite,h3,codegen\" -c \"blueBright.bold,cyanBright.bold,greenBright.bold\" \"vite\" \"PORT=3332 node --env-file=.env --import tsx --watch server/main.ts\" \"graphql-codegen --config codegen.ci.ts --watch\"",
    "build": "npm run lint:check && npm run codegen:ci && vite build && npm run typecheck",
    "preview": "fuser -k 3333/tcp || true && vite preview --port 3333",
    "start": "fuser -k 3333/tcp || true && PORT=3333 NODE_ENV=production node --env-file=.env --import tsx server/main.ts",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "codegen:ci": "graphql-codegen --config codegen.ci.ts",
    "codegen:schema": "graphql-codegen --config codegen.schema.ts",
    "db:setup": "npm run db:generate && npm run db:migrate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.0",
    "@unhead/vue": "^2.0.0",
    "@vueup/vue-quill": "^1.2.0",
    "@vueuse/core": "^13.0.0",
    "arctic": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.0",
    "graphql": "^16.0.0",
    "graphql-yoga": "^5.0.0",
    "h3": "^1.15.0",
    "iron-session": "^8.0.0",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.0",
    "postgres": "^3.4.0",
    "reka-ui": "^2.9.0",
    "sanitize-html": "^2.13.0",
    "sirv": "^3.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.0",
    "vue-i18n": "^11.0.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/schema-ast": "^5.0.1",
    "@graphql-codegen/typescript": "^4.0.0",
    "@graphql-codegen/typescript-operations": "^4.0.0",
    "@parcel/watcher": "^2.5.6",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/sanitize-html": "^2.13.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/eslint-config-prettier": "^10.0.0",
    "@vue/eslint-config-typescript": "^14.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "~5.8.0",
    "unplugin-auto-import": "^19.0.0",
    "unplugin-vue-components": "^28.0.0",
    "vite": "^6.0.0",
    "vue-tsc": "^3.0.0"
  }
}